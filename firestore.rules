rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Regla base: Solo usuarios autenticados pueden leer y escribir.
    // Esto previene el acceso público y soluciona la advertencia de vencimiento.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
